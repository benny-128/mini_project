<!DOCTYPE html>
<html>

<head>

<title>User Dashboard</title>

<link rel="stylesheet" href="/style.css">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

</head>

<body>

<div class="container">

<div class="glass p-4 mt-5">

<!-- TOP NAVIGATION -->

<div class="d-flex justify-content-between mb-4">


<a href="/logout" class="btn btn-danger">
🚪 Logout
</a>

</div>


<h2 class="text-center text-white mb-4">
Welcome <%= user.name %>
</h2>


<!-- ACTION BUTTONS -->

<div class="row text-center g-4">

<div class="col-md-6">

<div class="glass dashboard-card">

<h3>📚 Request Book</h3>

<a href="/request" class="btn btn-lib">
Request Book
</a>

</div>

</div>

<div class="col-md-6">

<div class="glass dashboard-card">

<h3>📚 Books History</h3>

<a href="/my-books" class="btn btn-lib">
View All Books
</a>

</div>

</div>


<div class="col-md-6">

<div class="glass dashboard-card">

<h3>↩ Return Book</h3>

<a href="/return" class="btn btn-lib">
Return Book
</a>

</div>

</div>

</div>



<!-- ISSUED BOOKS -->

<h3 class="text-white mt-5">📖 Issued Books</h3>

<div class="glass p-3">

<table class="table table-dark table-hover">

<tr>
<th>Book Name</th>
<th>Issue Date</th>
<th>Due Date</th>
</tr>


<% if(books.length === 0){ %>

<tr>
<td colspan="3" class="text-center">
No books issued
</td>
</tr>

<% } %>


<% books.forEach(function(book){ %>

<tr>

<td><%= book.title %></td>
<td><%= book.issue_date || '-' %></td>
<td><%= book.due_date || '-' %></td>

</tr>

<% }) %>

</table>

</div>

</div>

</div>

</body>

</html>