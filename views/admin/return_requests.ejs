<!DOCTYPE html>
<html>

<head>

<title>Return Requests</title>

<link rel="stylesheet" href="/style.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

</head>

<body>

<div class="main">

<h1 class="text-white mb-4">🔄 Return Requests</h1>

<div class="glass p-3">

<table class="table table-dark">

<tr>
<th>User</th>
<th>Book</th>
<th>Action</th>
</tr>

<% if(returns.length === 0){ %>

<tr>
<td colspan="3" class="text-center">No Return Requests</td>
</tr>

<% } %>

<% returns.forEach(function(r){ %>

<tr>

<td><%= r.name %></td>
<td><%= r.title %></td>

<td>
<a href="/accept-return/<%= r.id %>" class="btn btn-success btn-sm">
Accept Return
</a>
</td>

</tr>

<% }) %>

</table>

</div>

</div>

</body>
</html>