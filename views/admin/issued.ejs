<!DOCTYPE html>
<html>

<head>

<title>Issued Books</title>

<link rel="stylesheet" href="/style.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

</head>

<body>

<div class="container">

<div class="glass p-4 mt-5">

<h2 class="text-white mb-4">📖 Issued Books</h2>

<table class="table table-dark table-hover">

<tr>
<th>User</th>
<th>Book</th>
<th>Issue Date</th>
<th>Due Date</th>
<th>Status</th>
<th>Action</th>
</tr>
<form method="GET" action="/issued" class="mb-3">

<input type="text" 
name="search" 
placeholder="Search Roll No / Teacher ID"
value="<%= search %>"
class="form-control">

</form>

<% data.forEach(function(book){ %>

<tr>

<td><%= book.name %></td>
<td><%= book.title %></td>
<td><%= book.issue_date %></td>
<td><%= book.due_date %></td>
<td>
    <a herf="/return-book/<%= row.id %>" class="btn btn-danger">
        Return
    </a>
</td>
<td>

<% if(book.status === 'issued'){ %>

<span class="badge bg-success">Issued</span>

<% } else { %>

<span class="badge bg-danger">Returned</span>

<% } %>

</td>

</tr>

<% }) %>

</table>

</div>

</div>

</body>
</html>