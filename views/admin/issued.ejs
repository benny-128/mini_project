<!DOCTYPE html>
<html>

<head>
    <title>Issued Books</title>

    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
</head>

<body>

<div class="container">

    <!-- Dashboard Button -->
    <a href="/admin" class="btn btn-light mt-4">🏠 Dashboard</a>

    <div class="glass p-4 mt-4">

        <h2 class="text-white mb-4">📖 Issued Books</h2>

        <!-- 🔍 Search Box -->
        <form method="GET" action="/issued" class="mb-3">
            <input type="text"
                   name="search"
                   placeholder="Search Roll No / Teacher ID"
                   value="<%= search %>"
                   class="form-control">
        </form>

        <table class="table table-dark table-hover text-center">

            <thead>
                <tr>
                    <th>User</th>
                    <th>Book</th>
                    <th>Issue Date</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>

            <% if(data.length === 0){ %>
                <tr>
                    <td colspan="6">No records found</td>
                </tr>
            <% } %>

            <% data.forEach(function(book){ %>

                <tr>

                    <td><%= book.name %></td>

                    <td><%= book.title %></td>

                    <td><%= new Date(book.issue_date).toDateString() %></td>

                    <td><%= new Date(book.due_date).toDateString() %></td>

                    <!-- STATUS -->
                    <td>
                        <% if(book.status === 'issued'){ %>
                            <span class="badge bg-success">Issued</span>
                        <% } else { %>
                            <span class="badge bg-danger">Returned</span>
                        <% } %>
                    </td>

                    <!-- ACTION -->
                    <td>
                        <% if(book.status === 'issued'){ %>
                            <a href="/return-book/<%= book.id %>"
                               onclick="return confirm('Return this book?')"
                               class="btn btn-danger btn-sm">
                               Return
                            </a>
                        <% } else { %>
                            <span class="text-muted">Completed</span>
                        <% } %>
                    </td>

                </tr>

            <% }) %>

            </tbody>

        </table>

    </div>

</div>

</body>
</html>