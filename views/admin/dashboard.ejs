<!DOCTYPE html>
<html>

<head>

<title>Admin Dashboard</title>

<link rel="stylesheet" href="/style.css">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

</head>

<body>

<div class="sidebar">

<h2>📚 Library</h2>

<a href="/admin">Dashboard</a>
<a href="/books">View Books</a>
<a href="/students">Students</a>
<a href="/teachers">Teachers</a>
<a href="/requests">Book Requests</a>
<a href="/issued">Issued Books</a>
<a href="/returned">Returned Books</a>
<a href="/overdue">Overdue Books</a>
<a href="/return-requests">Return Requests</a>

<hr style="color:white">

<a href="/logout" style="color:#ff6b6b;">
🚪 Logout
</a>

</div>


<div class="main">

<h1 class="text-white mb-4">Admin Dashboard</h1>


<div class="row g-4">

<div class="col-md-4">
<div class="glass dashboard-card">
<h3>📚 Books</h3>
<a href="/books" class="btn btn-lib">View Books</a>
</div>
</div>


<div class="col-md-4">
<div class="glass dashboard-card">
<h3>👨‍🎓 Students</h3>
<a href="/students" class="btn btn-lib">View Students</a>
</div>
</div>


<div class="col-md-4">
<div class="glass dashboard-card">
<h3>👨‍🏫 Teachers</h3>
<a href="/teachers" class="btn btn-lib">View Teachers</a>
</div>
</div>


<div class="col-md-4">
<div class="glass dashboard-card">
<h3>📥 Requests</h3>
<a href="/requests" class="btn btn-lib">View Requests</a>
</div>
</div>


<div class="col-md-4">
<div class="glass dashboard-card">
<h3>📖 Issued Books</h3>
<a href="/issued" class="btn btn-lib">View Issued</a>
</div>
</div>


<div class="col-md-4">
<div class="glass dashboard-card">
<h3>⏰ Overdue</h3>
<a href="/overdue" class="btn btn-lib">View Overdue</a>
</div>
</div>

</div>


<h3 class="text-white mt-4">🆕 New Registrations</h3>

<div class="glass p-3">

<table class="table table-dark table-hover">

<tr>
<th>Name</th>
<th>Role</th>
<th>ID</th>
<th>Action</th>
</tr>

<% if(newUsers.length === 0){ %>

<tr>
<td colspan="4" class="text-center">
No new registrations
</td>
</tr>

<% } %>


<% newUsers.forEach(function(user){ %>

<tr>

<td><%= user.name %></td>
<td><%= user.role %></td>
<td><%= user.login_id %></td>

<td>

<a href="/approve-user/<%= user.id %>" class="btn btn-success btn-sm">
Approve
</a>

<a href="/delete-user/<%= user.id %>" class="btn btn-danger btn-sm">
Delete
</a>

</td>

</tr>

<% }) %>

</table>

</div>

</div>

</body>
</html>