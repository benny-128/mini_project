<!DOCTYPE html>
<html>

<head>

<title>Students</title>

<link rel="stylesheet" href="/style.css">

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

</head>

<body>

<div class="container mt-5">

<a href="/admin" class="btn btn-light mb-3">⬅ Dashboard</a>

<div class="glass p-4">

<h2 class="text-white mb-4">🎓 Students</h2>


<!-- SEARCH BAR -->

<form method="GET" action="/students" class="mb-4">

<div class="input-group">

<input
type="text"
name="search"
class="form-control"
placeholder="Search Student Roll No">

<button class="btn btn-success">
Search
</button>

</div>

</form>



<table class="table table-dark table-hover">

<thead>

<tr>
<th>Name</th>
<th>Login ID</th>
<th>Year</th>
<th>Branch</th>
<th>Mobile</th>
</tr>

</thead>

<tbody>


<% if(students.length === 0){ %>

<tr>
<td colspan="5" class="text-center">
Search a student Roll No to view details
</td>
</tr>

<% } %>



<% students.forEach(function(student){ %>

<tr>

<td><%= student.name %></td>

<td><%= student.login_id %></td>

<td><%= student.year %> Year</td>

<td><%= student.branch %></td>

<td><%= student.mobile %></td>

</tr>

<% }) %>


</tbody>

</table>

</div>

</div>

</body>

</html>