<!DOCTYPE html>
<html>

<head>

<title>Books</title>

<link rel="stylesheet" href="/style.css">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

</head>

<body>

<div class="sidebar">

<h2>📚 Library</h2>

<a href="/admin">Dashboard</a>
<a href="/books">Books</a>

</div>

<div class="main">

<h1 class="text-white mb-4">Books</h1>

<div class="glass p-4">

<table class="table table-dark table-striped">

<thead>

<tr>
<th>ID</th>
<th>Title</th>
<th>Author</th>
<th>Available</th>
</tr>

</thead>

<tbody>

<% books.forEach(function(book){ %>

<tr>

<td><%= book.id %></td>
<td><%= book.title %></td>
<td><%= book.author %></td>
<td><%= book.available_quantity %></td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</body>

</html>