<!DOCTYPE html>
<html>

<head>
<title>Teachers</title>

<link rel="stylesheet" href="/style.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

</head>

<body>

<div class="container mt-4">

<a href="/admin" class="btn btn-light mb-3">
⬅ Dashboard
</a>

<div class="glass p-4">

<h2 class="text-white mb-4">👨‍🏫 Teachers</h2>


<!-- SEARCH BAR -->

<form method="GET" action="/teachers" class="mb-4">

<div class="input-group">

<input
type="text"
name="search"
class="form-control"
placeholder="Search Teacher ID">

<button class="btn btn-success">
Search
</button>

</div>

</form>



<table class="table table-dark table-hover">

<thead>

<tr>
<th>Name</th>
<th>Login ID</th>
<th>Department</th>
<th>Mobile</th>
</tr>

</thead>

<tbody>


<% if(teachers.length === 0){ %>

<tr>
<td colspan="4" class="text-center">
Enter Teacher ID to search
</td>
</tr>

<% } %>


<% teachers.forEach(function(teacher){ %>

<tr>

<td><%= teacher.name %></td>

<td><%= teacher.login_id %></td>

<td><%= teacher.branch %></td>

<td><%= teacher.mobile %></td>

</tr>

<% }) %>


</tbody>

</table>

</div>

</div>

</body>
</html>