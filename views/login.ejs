<!DOCTYPE html>
<html>

<head>

<title>Library Login</title>

<link rel="stylesheet" href="/style.css">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

<style>

.login-container{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
}

.login-box{
width:350px;
padding:40px;
}

input{
margin-bottom:15px;
}

</style>

</head>

<body>

<div class="login-container">

<div class="glass login-box">

<h2 class="text-center mb-4">📚 Library Login</h2>

<form method="POST" action="/login">

<input 
type="text" 
name="login_id" 
class="form-control"
placeholder="Roll No / Teacher ID"
required
>

<input 
type="password" 
name="password"
class="form-control"
placeholder="Password"
required
>

<button class="btn btn-lib w-100">Login</button>
<div class="text-center mt-3">

<p style="color:white;">New user?</p>

<a href="/register" class="btn btn-lib">Register Here</a>

</div>

</form>

</div>

</div>

</body>

</html>